# ticket-loop Telegram bridge — copy these two lines into your repo-root .env
# (telegram.py reads the environment first, then falls back to <repo>/.env)

# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=123456789:AAabcdefghijklmnopqrstuvwxyz

# The dedicated group's chat id — get it with:
#   python3 .claude/skills/ticket-loop/telegram.py discover
# (group ids are negative, supergroups start with -100)
AGENT_TELEGRAM_CHAT_ID=-1001234567890
